{
  "name": "pi-node-toolbox",
  "private": true,
  "version": "26.0.1",
  "author": "Yegou",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:dir": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.yegou.pi-node-toolbox",
    "productName": "Pi节点工具箱",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "Pi节点工具箱_${version}_便携版.exe"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "motion": "^12.10.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.1.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^8.0.3"
  }
}
